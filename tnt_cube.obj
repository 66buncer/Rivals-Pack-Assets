# TNT-style cube mesh, 1x1x1, unit cube centered at origin
# Single-texture setup: use tnt_atlas.png as the one texture for the whole mesh.
# Atlas layout (4 segments of 16px each, total 64x16):
#   segment 0 (u 0.00-0.25): side texture (TNT label)
#   segment 1 (u 0.25-0.50): side texture (TNT label) -- duplicate, same art
#   segment 2 (u 0.50-0.75): top texture
#   segment 3 (u 0.75-1.00): bottom texture
mtllib tnt_cube.mtl
o TNT_Cube

v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5

# Side UVs use segment 0 (u: 0.0-0.25)
vt 0.00 0.0
vt 0.25 0.0
vt 0.25 1.0
vt 0.00 1.0

# Top UVs use segment 2 (u: 0.5-0.75)
vt 0.50 0.0
vt 0.75 0.0
vt 0.75 1.0
vt 0.50 1.0

# Bottom UVs use segment 3 (u: 0.75-1.0)
vt 0.75 0.0
vt 1.00 0.0
vt 1.00 1.0
vt 0.75 1.0

vn  0.0  0.0  1.0
vn  0.0  0.0 -1.0
vn  1.0  0.0  0.0
vn -1.0  0.0  0.0
vn  0.0  1.0  0.0
vn  0.0 -1.0  0.0

usemtl tnt_atlas
g front
f 1/1/1 2/2/1 3/3/1 4/4/1

g back
f 6/1/2 5/2/2 8/3/2 7/4/2

g right
f 2/1/3 6/2/3 7/3/3 3/4/3

g left
f 5/1/4 1/2/4 4/3/4 8/4/4

g top
f 4/5/5 3/6/5 7/7/5 8/8/5

g bottom
f 5/9/6 6/10/6 2/11/6 1/12/6
